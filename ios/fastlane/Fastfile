default_platform(:ios)

platform :ios do
  private_lane :app_store_connect_api_key_from_env do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY")
    )
  end

  private_lane :flutter_build_name do
    pubspec = File.read(File.expand_path("../../pubspec.yaml", __dir__))
    version_line = pubspec.lines.find { |line| line.start_with?("version:") }
    UI.user_error!("version is missing in pubspec.yaml") unless version_line

    version_line.split(":", 2).last.strip.split("+", 2).first
  end

  private_lane :next_testflight_build_number do |options|
    version = options.fetch(:version)
    api_key = options.fetch(:api_key)
    latest_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.basematch.app",
      version: version,
      initial_build_number: 0
    )

    latest_build_number.to_i + 1
  end

  desc "Create or sync App Store signing certificates and profiles"
  lane :sync_signing do
    api_key = app_store_connect_api_key_from_env

    match(
      type: "appstore",
      readonly: false,
      api_key: api_key
    )
  end

  desc "Build a signed iOS IPA and upload it to TestFlight"
  lane :beta do
    setup_ci if is_ci

    api_key = app_store_connect_api_key_from_env

    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key
    )

    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      .fetch("com.basematch.app")
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      targets: ["Runner"],
      build_configurations: ["Release", "Profile"],
      team_id: "TFGTJ2C22L",
      bundle_identifier: "com.basematch.app",
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    build_name = flutter_build_name
    build_number = next_testflight_build_number(
      api_key: api_key,
      version: build_name
    )

    sh(
      "cd .. && flutter build ipa --release " \
      "--build-name #{build_name} " \
      "--build-number #{build_number} " \
      "--export-method app-store"
    )

    ipa_path = Dir[File.expand_path("../../build/ios/ipa/*.ipa", __dir__)]
      .max_by { |path| File.mtime(path) }
    UI.user_error!("No IPA was generated under build/ios/ipa") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      uses_non_exempt_encryption: false,
      skip_waiting_for_build_processing: true
    )
  end
end
